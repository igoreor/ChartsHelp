# Configurações do GitHub
GITHUB_OWNER=seu-usuario
GITHUB_REPO=charts-help-docs
GITHUB_BRANCH=main
# Token com permissão de leitura (evita rate limit do GitHub: 60 req/h sem token, 5000 com token)
GITHUB_TOKEN=

# Servidor
PORT=3000

# CORS — coloque a URL do seu frontend em produção
CORS_ORIGIN=*

# Cache em minutos (padrão: 10)
CACHE_TTL_MINUTES=10
